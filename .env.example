# Required — Gemini AI
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Required in production
JWT_SECRET="CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING"
NODE_ENV=production

# App URL (used for CORS, canonical URLs)
APP_URL="https://cofounder.uprisingstudio.ca"
CORS_ORIGIN="https://cofounder.uprisingstudio.ca"
PORT=3000

# Bland AI (optional)
BLAND_API_KEY=

# Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ElevenLabs (optional)
ELEVENLABS_API_KEY=

# Twenty CRM (optional)
TWENTY_API_KEY=
TWENTY_API_URL=https://api.twenty.com

# SMTP settings (for Email Verification & Password Reset)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Uprising Cofounder <noreply@uprising-cofounder.com>"

# AWS S3 Configuration for Image Uploads
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
