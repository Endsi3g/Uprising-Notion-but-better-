# ============================================================
# Uprising CRM — Configuration Environnement
# ============================================================
# Copier ce fichier vers .env et remplir les valeurs.
# Configuration optimisée pour agence auto-hébergée
# avec outils gratuits / open source.
# ============================================================

# ---- Sécurité (OBLIGATOIRE — générer des secrets uniques) ----
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACCESS_TOKEN_SECRET=CHANGE_ME_generate_with_crypto
REFRESH_TOKEN_SECRET=CHANGE_ME_generate_with_crypto
LOGIN_TOKEN_SECRET=CHANGE_ME_generate_with_crypto
FILE_TOKEN_SECRET=CHANGE_ME_generate_with_crypto

# ---- Base de données ----
PG_DATABASE_URL=postgres://uprising:uprising@localhost:5432/uprising

# ---- Serveur ----
FRONTEND_URL=http://localhost:3001
# PORT=3000

# ---- Ollama (LLM — gratuit, local) ----
# Installer : https://ollama.com
# Puis : ollama pull llama3.1 && ollama pull mistral
# IMPORTANT : Ollama écoute par défaut sur localhost uniquement (sécurisé)
OPENAI_COMPATIBLE_BASE_URL=http://localhost:11434/v1
OPENAI_COMPATIBLE_MODEL_NAMES=llama3.1,mistral,codellama
OPENAI_COMPATIBLE_API_KEY=ollama

# ---- Browserless (navigateur headless — gratuit, auto-hébergé) ----
# Docker : docker run -p 3333:3000 ghcr.io/browserless/chromium
# SÉCURITÉ : En production, utiliser un token pour protéger l'instance
BROWSERLESS_URL=ws://localhost:3333
# BROWSERLESS_TOKEN=votre_token_securise_ici

# ---- Email (SMTP) ----
EMAIL_DRIVER=SMTP
EMAIL_FROM_ADDRESS=noreply@votre-agence.com
EMAIL_FROM_NAME=Uprising CRM
EMAIL_SYSTEM_ADDRESS=system@votre-agence.com
EMAIL_SMTP_HOST=smtp.votre-agence.com
EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=
# EMAIL_SMTP_PASSWORD=

# ---- Google OAuth (Email + Calendar) ----
# 1. Aller sur https://console.cloud.google.com
# 2. Créer un projet → Activer Gmail API + Calendar API
# 3. Credentials → Create OAuth 2.0 Client ID
# 4. Ajouter les Authorized redirect URIs :
#    - http://localhost:3000/auth/google/redirect
#    - http://localhost:3000/auth/google-apis/get-access-token
AUTH_GOOGLE_ENABLED=true
# AUTH_GOOGLE_CLIENT_ID=votre_client_id.apps.googleusercontent.com
# AUTH_GOOGLE_CLIENT_SECRET=votre_client_secret
AUTH_GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/redirect
AUTH_GOOGLE_APIS_CALLBACK_URL=http://localhost:3000/auth/google-apis/get-access-token

# ---- Services payants (tous DÉSACTIVÉS par défaut) ----
# IS_BILLING_ENABLED=false
# EXCEPTION_HANDLER_DRIVER=CONSOLE
# CODE_INTERPRETER_TYPE=DISABLED

# ---- Optionnel : Clés LLM commerciales (fallback si Ollama indisponible) ----
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# XAI_API_KEY=
# GROQ_API_KEY=

# ---- Instagram Monitor ----
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
INSTAGRAM_MONITOR_INTERVAL=300 # seconds
