# Stage 1: Builder
FROM node:20-slim AS builder

WORKDIR /app

# Install system dependencies needed for build (e.g., Prisma)
RUN apt-get update && apt-get install -y \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy package files separately to leverage caching
COPY package*.json ./
COPY prisma ./prisma/

# Install dependencies with cache mount
RUN --mount=type=cache,target=/root/.npm \
    npm install

# Generate Prisma client
RUN npx prisma generate

# Copy source code and build if necessary (currently using tsx, so no build step)
COPY . .

# Stage 2: Runtime
FROM node:20-slim AS runtime

WORKDIR /app

# Install runtime system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    lsb-release \
    zstd \
    && rm -rf /var/lib/apt/lists/*

# Copy from builder
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/package.json ./package.json
COPY --from=builder /app/prisma ./prisma
COPY --from=builder /app/scripts ./scripts
COPY --from=builder /app/server ./server
COPY --from=builder /app/src ./src

# Install Ollama (Slow operation, moved to end so code changes don't bust cache)
RUN curl -fsSL https://ollama.com/install.sh | sh

# Expose ports
EXPOSE 3000 11434

# Ensure entrypoint script is executable
RUN chmod +x ./scripts/docker-entrypoint.sh

# Use entrypoint script to manage Ollama and Node
ENTRYPOINT ["./scripts/docker-entrypoint.sh"]

