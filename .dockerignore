# .dockerignore — Uprising Studio CRM
# Reduces Docker build context to only files needed by the Dockerfile.
# Smaller context = faster uploads to the daemon and faster builds.

# ─── Version control ──────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes
.github

# ─── Local env / secrets ──────────────────────────────────────────────────────
.env
.env.*
!.env.example
packages/twenty-server/.env

# ─── Node / Yarn artefacts ────────────────────────────────────────────────────
node_modules
**/node_modules
.yarn/cache
.yarn/install-state.gz

# ─── Build / cache outputs ────────────────────────────────────────────────────
dist
**/dist
build
**/build
.swc
**/.swc
.nx/cache
.cache
**/.cache
coverage
**/coverage

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── IDE / OS ─────────────────────────────────────────────────────────────────
.vscode
.idea
*.DS_Store
Thumbs.db

# ─── Test / docs (not needed in the image) ────────────────────────────────────
**/__tests__
**/*.test.ts
**/*.spec.ts
**/*.test.tsx
**/*.spec.tsx
docs
*.md
!packages/twenty-server/src/**/*.md

# ─── Scripts & tooling (not needed at runtime) ────────────────────────────────
scripts
packages/twenty-docker/voice-agency

# ─── Storybook ────────────────────────────────────────────────────────────────
**/.storybook
**/storybook-static
